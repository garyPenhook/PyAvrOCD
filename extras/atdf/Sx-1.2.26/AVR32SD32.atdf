        <register caption="LUT 0 Control B" initval="0x00" name="LUT0CTRLB" offset="0x09" rw="RW" size="1">
          <bitfield caption="LUT Input 0 Source Selection" mask="0x0F" name="INSEL0" rw="RW" values="CCL_INSEL0"/>
