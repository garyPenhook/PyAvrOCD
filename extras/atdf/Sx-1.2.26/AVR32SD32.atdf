      <value-group caption="ALARM State Interrupt Type select" name="ERRCTRL_INTTYPE">
        <value caption="Interrupt" name="INT" value="0x0"/>
        <value caption="Non-maskable interrupt" name="NMI" value="0x1"/>
      </value-group>
      <value-group caption="ERRCTRL State select" name="ERRCTRL_STATE">
        <value caption="Configuration state" name="CONFIG" value="0x0"/>
        <value caption="Normal state" name="NORMAL" value="0x1"/>
        <value caption="Alarm state" name="ALARM" value="0x2"/>
        <value caption="Fault state" name="FAULT" value="0x3"/>
      </value-group>
      <value-group caption="Error Severity Level select" name="ERRCTRL_ERRLVL">
        <value caption="Critical error" name="CRITICAL" value="0x0"/>
        <value caption="Noncritical error (reset value)" name="NONCRITICAL" value="0x2"/>
        <value caption="Notification error" name="NOTIFICATION" value="0x3"/>
      </value-group>
      <value-group caption="Critical Error Detected select" name="ERRCTRL_CRITICAL">
        <value caption="There are no Critical errors in the system" name="NOERROR" value="0x0"/>
        <value caption="There are one or more Critical errors in the system" name="ERROR" value="0x1"/>
      </value-group>
      <value-group caption="Float I/O pins select" name="ERRCTRL_FLOAT">
        <value caption="I/O pins are not forced to floating state" name="NORMAL" value="0x0"/>
        <value caption="I/O pins are forced to floating state" name="FLOAT" value="0x1"/>
      </value-group>
      <value-group caption="All I/O pins are in safe state select" name="ERRCTRL_IOSAFE">
        <value caption="One or more I/O pins are not in safe state" name="NOSAFE" value="0x0"/>
        <value caption="All I/O pins are in a safe state" name="SAFE" value="0x1"/>
      </value-group>
      <value-group caption="Noncritical Error Detected select" name="ERRCTRL_NONCRITICAL">
        <value caption="There are no Noncritical errors in the system" name="NOERROR" value="0x0"/>
        <value caption="There are one or more Noncritical errors in the system" name="ERROR" value="0x1"/>
      </value-group>
      <value-group caption="Notification Error Detected select" name="ERRCTRL_NOTIFICATION">
        <value caption="There are no Notification errors in the system" name="NOERROR" value="0x0"/>
        <value caption="There are one or more Notification errors in the system" name="ERROR" value="0x1"/>
      </value-group>
    </module>
