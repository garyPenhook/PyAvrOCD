    <module caption="Fuses" id="avrsd" name="FUSE">
      <register-group caption="Fuses" name="FUSE" size="0x0C">
        <register caption="Watchdog Configuration" initval="0x00" name="WDTCFG" offset="0x0" rw="RW" size="1">
