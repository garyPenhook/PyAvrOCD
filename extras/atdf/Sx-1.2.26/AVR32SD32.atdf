        <value caption="CFD 1" name="CFD1" value="0xA"/>
        <value caption="CFM Frequency Error 0" name="CFM0" value="0xB"/>
        <value caption="CFM Frequency Error 1" name="CFM1" value="0xC"/>
        <value caption="SWDT Error" name="SWDT" value="0xD"/>
        <value caption="EEPROM ECC error" name="EEPROM" value="0xE"/>
        <value caption="Event system input 0" name="EVSYS0" value="0xF"/>
        <value caption="Event system input 1" name="EVSYS1" value="0x10"/>
