        <register caption="Sequential Control 1" initval="0x00" name="SEQCTRL1" offset="0x02" rw="RW" size="1">
          <bitfield caption="Sequential Selection" mask="0x0F" name="SEQSEL" rw="RW" values="CCL_SEQSEL"/>
