        <value caption="IO Register Protection" name="IOREG" value="0xD8"/>
      </value-group>
    </module>
    <module caption="Interrupt Controller" id="int_8bit_v3" name="CPUINT">
      <register-group caption="Interrupt Controller" name="CPUINT" size="0x10">
        <register caption="Control A" initval="0x00" name="CTRLA" offset="0x0" rw="RW" size="1">
          <bitfield caption="Round-robin Scheduling Enable" mask="0x01" name="LVL0RR" rw="RW"/>
          <bitfield caption="Compact Vector Table" mask="0x20" name="CVT" rw="RW"/>
          <bitfield caption="Interrupt Vector Select" mask="0x40" name="IVSEL" rw="RW"/>
        </register>
        <register caption="Status" initval="0x00" name="STATUS" offset="0x1" rw="R" size="1">
          <bitfield caption="Level 0 Interrupt Executing" mask="0x01" name="LVL0EX" rw="R"/>
          <bitfield caption="Level 1 Interrupt Executing" mask="0x02" name="LVL1EX" rw="R"/>
          <bitfield caption="Non-maskable Interrupt Executing" mask="0x80" name="NMIEX" rw="R"/>
        </register>
        <register caption="Interrupt Level 0 Priority" initval="0x00" name="LVL0PRI" offset="0x2" rw="RW" size="1">
          <bitfield caption="Interrupt Level Priority" mask="0xFF" name="LVL0PRI" rw="RW"/>
        </register>
        <register caption="Interrupt Level 1 Priority Vector" initval="0x00" name="LVL1VEC" offset="0x3" rw="RW" size="1">
          <bitfield caption="Interrupt Vector with High Priority" mask="0xFF" name="LVL1VEC" rw="RW"/>
        </register>
      </register-group>
    </module>
    <module caption="CRCSCAN" id="math_pdi_crc_avr_v2" name="CRCSCAN">
      <register-group caption="CRCSCAN" name="CRCSCAN" size="0x10">
        <register caption="Control A" initval="0x00" name="CTRLA" offset="0x0" rw="RW" size="1">
          <bitfield caption="Enable CRCSCAN" mask="0x01" name="ENABLE" rw="RW"/>
          <bitfield caption="Enable NMI Trigger" mask="0x02" name="NMIEN" rw="RW"/>
          <bitfield caption="CRC Mode Select" mask="0x08" name="CRCSEL" rw="RW" values="CRCSCAN_CRCSEL"/>
          <bitfield caption="Enable Periodic Timer" mask="0x10" name="PEREN" rw="RW" values="CRCSCAN_PEREN"/>
          <bitfield caption="CRC Source" mask="0x60" name="SRC" rw="RW" values="CRCSCAN_SRC"/>
          <bitfield caption="Reset CRCSCAN" mask="0x80" name="RESET" rw="RW"/>
        </register>
        <register caption="Control B" initval="0x00" name="CTRLB" offset="0x1" rw="W" size="1">
          <bitfield caption="Inject CRC error" mask="0x01" name="EINJ" rw="W"/>
        </register>
        <register caption="Interrupt Control" initval="0x00" name="INTCTRL" offset="0x2" rw="RW" size="1">
          <bitfield caption="Scan Done Interrupt Enable" mask="0x01" name="DONE" rw="RW"/>
          <bitfield caption="Scan Period Done Interrupt Enable" mask="0x02" name="PERIOD" rw="RW"/>
        </register>
        <register caption="Interrupt Flags" initval="0x00" name="INTFLAGS" offset="0x3" rw="RW" size="1">
          <bitfield caption="Scan Done" mask="0x01" name="DONE" rw="RW"/>
          <bitfield caption="Scan Period Done" mask="0x02" name="PERIOD" rw="RW"/>
        </register>
        <register caption="Status A" initval="0x04" name="STATUSA" offset="0x4" rw="R" size="1">
          <bitfield caption="Error Signal driving NMI" mask="0x01" name="ERROR" rw="R"/>
          <bitfield caption="CRC BUSY" mask="0x02" name="BUSY" rw="R"/>
          <bitfield caption="CRC OK" mask="0x04" name="OK" rw="R"/>
        </register>
        <register caption="Scan Address" initval="0x00" name="SCANADR" offset="0x5" rw="R" size="1">
          <bitfield caption="Address Being Scanned" mask="0xFF" name="SCANADR" rw="R"/>
        </register>
        <register caption="Input Data" initval="0x00" name="DATA" offset="0x6" rw="W" size="1">
          <bitfield caption="Input Data" mask="0xFF" name="DATA" rw="W"/>
        </register>
        <register caption="CRC Result" initval="0xFFFFFFFF" name="CRC" offset="0x8" rw="R" size="4">
          <bitfield caption="CRC Result" mask="0xFFFFFFFF" name="CRC" rw="R"/>
        </register>
      </register-group>
      <value-group caption="CRC Mode Select" name="CRCSCAN_CRCSEL">
        <value caption="The CRC is performed using CRC16" name="CRC16" value="0x0"/>
        <value caption="The CRC is performed using CRC32" name="CRC32" value="0x1"/>
      </value-group>
      <value-group caption="Enable Periodic Timer select" name="CRCSCAN_PEREN">
        <value caption="The periodic timer is disabled" name="DISABLE" value="0x0"/>
        <value caption="The periodic timer is enabled" name="ENABLE" value="0x1"/>
      </value-group>
      <value-group caption="CRC Source select" name="CRCSCAN_SRC">
        <value caption="The CRC is performed on the boot section of Flash" name="BOOT" value="0x0"/>
        <value caption="The CRC is performed on the application code section of Flash" name="CODE" value="0x1"/>
        <value caption="The CRC is performed on the application data section of Flash" name="DATA" value="0x2"/>
        <value caption="Manual mode, CRC is performed on data written to DATA" name="MANUAL" value="0x3"/>
      </value-group>
    </module>
    <module caption="Event System" id="ev_ctrl_v1" name="EVSYS">
      <register-group caption="Event System" name="EVSYS" size="0x80">
