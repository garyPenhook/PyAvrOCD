        <register caption="Pin 1 Control" initval="0x00" name="PIN1CTRL" offset="0x11" rw="RW" size="1">
          <bitfield caption="Input/Sense Configuration" mask="0x07" name="ISC" rw="RW" values="PORT_ISC"/>
          <bitfield caption="Pullup enable" mask="0x08" name="PULLUPEN" rw="RW"/>
          <bitfield caption="Input Level Select" mask="0x40" name="INLVL" rw="RW" values="PORT_INLVL"/>
