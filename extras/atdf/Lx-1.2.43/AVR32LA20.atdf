  <modules>
    <module caption="Analog Comparator" id="cmp_control_avr_v9" name="AC">
      <register-group caption="Analog Comparator" name="AC" size="0x8">
        <register caption="Control A" initval="0x00" name="CTRLA" offset="0x0" rw="RW" size="1">
          <bitfield caption="Enable AC" mask="0x01" name="ENABLE" rw="RW"/>
          <bitfield caption="Hysteresis Mode Select" mask="0x06" name="HYSMODE" rw="RW" values="AC_HYSMODE"/>
          <bitfield caption="Operation Select" mask="0x60" name="OPSEL" rw="RW" values="AC_OPSEL"/>
          <bitfield caption="Run in Standby Mode" mask="0x80" name="RUNSTDBY" rw="RW"/>
        </register>
        <register caption="Control B" initval="0x00" name="CTRLB" offset="0x1" rw="RW" size="1">
          <bitfield caption="Output initial value" mask="0x08" name="INITVAL" rw="RW" values="AC_INITVAL"/>
          <bitfield caption="Invert AC Output" mask="0x10" name="INVERT" rw="RW"/>
          <bitfield caption="Output Enable" mask="0x20" name="OUTEN" rw="RW"/>
        </register>
        <register caption="Multiplexer Control" initval="0x00" name="MUXCTRL" offset="0x2" rw="RW" size="1">
          <bitfield caption="Negative Input MUX Selection" mask="0x07" name="MUXNEG" rw="RW" values="AC_MUXNEG"/>
          <bitfield caption="Positive Input MUX Selection" mask="0x38" name="MUXPOS" rw="RW" values="AC_MUXPOS"/>
        </register>
        <register caption="Reference Scaling" initval="0xFF" name="REFSCALE" offset="0x3" rw="RW" size="1">
          <bitfield caption="Scaled Reference Voltage" mask="0xFF" name="REFSCALE" rw="RW"/>
        </register>
        <register caption="Interrupt Control" initval="0x00" name="INTCTRL" offset="0x4" rw="RW" size="1">
          <mode name="NORMAL" qualifier="WINSEL" value="0x0"/>
          <mode name="WINDOW" qualifier="WINSEL" value="0x1 0x2"/>
          <bitfield caption="Comparator Interrupt Enable" mask="0x01" name="CMP" rw="RW"/>
          <bitfield caption="Interrupt Mode" mask="0x30" modes="NORMAL" name="INTMODE" rw="RW" values="AC_NORMAL_INTMODE"/>
        </register>
        <register caption="Interrupt Flags" name="INTFLAGS" offset="0x5" rw="RW" size="1">
          <bitfield caption="Comparator Interrupt Flag" mask="0x01" name="CMP" rw="RW"/>
        </register>
        <register caption="Status" initval="0x00" name="STATUS" offset="0x6" rw="R" size="1">
          <bitfield caption="Analog Comparator State" mask="0x01" name="CMP" rw="R" values="AC_CMP"/>
        </register>
      </register-group>
      <value-group caption="Hysteresis Mode Select" name="AC_HYSMODE">
        <value caption="No hysteresis" name="NONE" value="0x00"/>
        <value caption="Small hysteresis" name="SMALL" value="0x01"/>
        <value caption="Medium hysteresis" name="MEDIUM" value="0x02"/>
        <value caption="Large hysteresis" name="LARGE" value="0x03"/>
      </value-group>
      <value-group caption="Operation Select" name="AC_OPSEL">
        <value caption="Continuous mode" name="CONT" value="0x0"/>
        <value caption="Event triggered mode" name="EVENT" value="0x1"/>
        <value caption="Sampled mode, 1 kHz sampling frequency" name="SAMP1K" value="0x2"/>
        <value caption="Sampled mode, 128 Hz sampling frequency" name="SAMP128" value="0x3"/>
      </value-group>
      <value-group caption="Output initial value select" name="AC_INITVAL">
        <value caption="Output initialized to 0" name="LOW" value="0x0"/>
        <value caption="Output initialized to 1" name="HIGH" value="0x1"/>
      </value-group>
      <value-group caption="Interrupt Mode select" name="AC_NORMAL_INTMODE">
        <value caption="Positive and negative inputs crosses" name="BOTHEDGE" value="0x0"/>
        <value caption="Positive input goes below negative input" name="NEGEDGE" value="0x2"/>
        <value caption="Positive input goes above negative input" name="POSEDGE" value="0x3"/>
      </value-group>
      <value-group caption="Negative Input MUX Selection" name="AC_MUXNEG">
        <value caption="Negative Pin 0" name="AINN0" value="0x0"/>
        <value caption="Negative Pin 1" name="AINN1" value="0x1"/>
        <value caption="Negative Pin 2" name="AINN2" value="0x2"/>
        <value caption="Reference Scaler" name="REFSCALE" value="0x4"/>
      </value-group>
      <value-group caption="Positive Input MUX Selection" name="AC_MUXPOS">
        <value caption="Positive Pin 0" name="AINP0" value="0x0"/>
        <value caption="Positive Pin 3" name="AINP3" value="0x3"/>
        <value caption="VDD divided by 10" name="VDDDIV10" value="0x7"/>
      </value-group>
      <value-group caption="Analog Comparator State select" name="AC_CMP">
        <value caption="Comparator output is low" name="LOW" value="0x0"/>
        <value caption="Comparator output is high" name="HIGH" value="0x1"/>
      </value-group>
    </module>
    <module caption="Analog to Digital Converter" id="adc_10b_ctrl_avr_v2" name="ADC">
      <register-group caption="Analog to Digital Converter" name="ADC" size="0x40">
        <register caption="Control A" initval="0x00" name="CTRLA" offset="0x00" rw="RW" size="1">
          <bitfield caption="ADC Enable" mask="0x01" name="ENABLE" rw="RW"/>
          <bitfield caption="Low Latency" mask="0x20" name="LOWLAT" rw="RW"/>
          <bitfield caption="Run in Standby Mode" mask="0x80" name="RUNSTDBY" rw="RW"/>
        </register>
        <register caption="Control B" initval="0x00" name="CTRLB" offset="0x01" rw="RW" size="1">
          <bitfield caption="ADC Prescaler" mask="0x1F" name="PRESC" rw="RW" values="ADC_PRESC"/>
        </register>
        <register caption="Control C" initval="0x00" name="CTRLC" offset="0x02" rw="RW" size="1">
          <bitfield caption="Reference Selection" mask="0x07" name="REFSEL" rw="RW" values="ADC_REFSEL"/>
        </register>
        <register caption="Control D" initval="0x00" name="CTRLD" offset="0x03" rw="RW" size="1">
          <bitfield caption="Window Comparator Mode" mask="0x07" name="WINCM" rw="RW" values="ADC_WINCM"/>
          <bitfield caption="Window Mode Source" mask="0x08" name="WINSRC" rw="RW" values="ADC_WINSRC"/>
        </register>
        <register caption="Control E" initval="0x00" name="CTRLE" offset="0x04" rw="RW" size="1">
          <bitfield caption="Sample Duration" mask="0xFF" name="SAMPDUR" rw="RW"/>
        </register>
        <register caption="Control F" initval="0x00" name="CTRLF" offset="0x05" rw="RW" size="1">
          <bitfield caption="Sample Accumulation Number Select" mask="0x0F" name="SAMPNUM" rw="RW" values="ADC_SAMPNUM"/>
          <bitfield caption="Result Scaling" mask="0x30" name="SCALING" rw="RW" values="ADC_SCALING"/>
          <bitfield caption="Free Running" mask="0x40" name="FREERUN" rw="RW"/>
        </register>
        <register caption="Interrupt Control" initval="0x00" name="INTCTRL" offset="0x06" rw="RW" size="1">
          <bitfield caption="Result Ready Interrupt Enable" mask="0x01" name="RESRDY" rw="RW"/>
          <bitfield caption="Sample Ready Interrupt Enable" mask="0x02" name="SAMPRDY" rw="RW"/>
          <bitfield caption="Window Comparator Interrupt Enable" mask="0x04" name="WCMP" rw="RW"/>
          <bitfield caption="Result Overwrite Interrupt Enable" mask="0x08" name="RESOVR" rw="RW"/>
          <bitfield caption="Sample Overwrite Interrupt Enable" mask="0x10" name="SAMPOVR" rw="RW"/>
          <bitfield caption="Trigger Overrun Interrupt Enable" mask="0x20" name="TRIGOVR" rw="RW"/>
        </register>
        <register caption="Interrupt Flags" initval="0x00" name="INTFLAGS" offset="0x07" rw="RW" size="1">
          <bitfield caption="Result Ready Interrupt Flag" mask="0x01" name="RESRDY" rw="RW"/>
          <bitfield caption="Sample Ready Interrupt Flag" mask="0x02" name="SAMPRDY" rw="RW"/>
          <bitfield caption="Window Comparator Interrupt Flag" mask="0x04" name="WCMP" rw="RW"/>
          <bitfield caption="Result Overwrite Interrupt Flag" mask="0x08" name="RESOVR" rw="RW"/>
          <bitfield caption="Sample Overwrite Interrupt Flag" mask="0x10" name="SAMPOVR" rw="RW"/>
          <bitfield caption="Trigger Overrun Interrupt Flag" mask="0x20" name="TRIGOVR" rw="RW"/>
        </register>
        <register caption="Status" initval="0x00" name="STATUS" offset="0x08" rw="R" size="1">
          <bitfield caption="ADC Busy" mask="0x01" name="ADCBUSY" rw="R"/>
        </register>
        <register caption="Debug Control" initval="0x00" name="DBGCTRL" offset="0x09" rw="RW" size="1">
          <bitfield caption="Run in Debug Mode" mask="0x01" name="DBGRUN" rw="RW"/>
        </register>
        <register caption="Command" initval="0x00" name="COMMAND" offset="0x0A" rw="RW" size="1">
          <bitfield caption="Start Conversion" mask="0x07" name="START" rw="RW" values="ADC_START"/>
          <bitfield caption="Mode" mask="0x70" name="MODE" rw="RW" values="ADC_MODE"/>
        </register>
        <register caption="Positive Input Multiplexer" initval="0x00" name="MUXPOS" offset="0x0B" rw="RW" size="1">
          <bitfield caption="Positive Input Multiplexer" mask="0x7F" name="MUXPOS" rw="RW" values="ADC_MUXPOS"/>
        </register>
        <register caption="Result" initval="0x0000" name="RESULT" offset="0x0C" rw="RW" size="2">
          <bitfield caption="ADC Result" mask="0xFFFF" name="RESULT" rw="R"/>
        </register>
        <register caption="Sample" initval="0x0000" name="SAMPLE" offset="0x0E" rw="RW" size="2">
          <bitfield caption="ADC Sample" mask="0xFFFF" name="SAMPLE" rw="R"/>
        </register>
        <register caption="Window Low Threshold" name="WINLT" offset="0x10" rw="RW" size="2">
          <bitfield caption="Window Low Threshold" mask="0xFFFF" name="WINLT" rw="RW"/>
        </register>
        <register caption="Window High Threshold" name="WINHT" offset="0x12" rw="RW" size="2">
          <bitfield caption="Window High Threshold" mask="0xFFFF" name="WINHT" rw="RW"/>
        </register>
        <register caption="Temporary" initval="0x00" name="TEMP" offset="0x14" rw="RW" size="1">
          <bitfield caption="Temporary" mask="0xFF" name="TEMP" rw="RW"/>
        </register>
      </register-group>
      <value-group caption="Mode select" name="ADC_MODE">
        <value caption="Single Conversion with 8-bit resolution" name="SINGLE_8BIT" value="0x0"/>
        <value caption="Single Conversion with 10-bit resolution" name="SINGLE_10BIT" value="0x1"/>
        <value caption="Series with accumulation, separate trigger for every 10-bit conversion" name="SERIES" value="0x2"/>
        <value caption="Burst with accumulation, one trigger will run SAMPNUM 10-bit conversions in one sequence" name="BURST" value="0x3"/>
        <value caption="Accumulator diagnostic mode" name="ACCTEST" value="0x7"/>
      </value-group>
      <value-group caption="Start Conversion select" name="ADC_START">
        <value caption="Stop an ongoing conversion" name="STOP" value="0x0"/>
        <value caption="Start a conversion immediately. This will be set back to STOP when the first conversion is done, unless Free-Running mode is enabled" name="IMMEDIATE" value="0x1"/>
        <value caption="Start when a write to the MUXPOS register is done" name="MUXPOS" value="0x2"/>
        <value caption="Start when an event is received by the ADC" name="EVENT" value="0x4"/>
      </value-group>
      <value-group caption="ADC Prescaler select" name="ADC_PRESC">
        <value caption="CLK_PER divided by 2" name="DIV2" value="0x00"/>
        <value caption="CLK_PER divided by 3" name="DIV3" value="0x01"/>
        <value caption="CLK_PER divided by 4" name="DIV4" value="0x02"/>
        <value caption="CLK_PER divided by 5" name="DIV5" value="0x03"/>
        <value caption="CLK_PER divided by 6" name="DIV6" value="0x04"/>
        <value caption="CLK_PER divided by 7" name="DIV7" value="0x05"/>
        <value caption="CLK_PER divided by 8" name="DIV8" value="0x06"/>
        <value caption="CLK_PER divided by 9" name="DIV9" value="0x07"/>
        <value caption="CLK_PER divided by 10" name="DIV10" value="0x08"/>
        <value caption="CLK_PER divided by 11" name="DIV11" value="0x09"/>
        <value caption="CLK_PER divided by 12" name="DIV12" value="0x0A"/>
        <value caption="CLK_PER divided by 13" name="DIV13" value="0x0B"/>
        <value caption="CLK_PER divided by 14" name="DIV14" value="0x0C"/>
        <value caption="CLK_PER divided by 15" name="DIV15" value="0x0D"/>
        <value caption="CLK_PER divided by 16" name="DIV16" value="0x0E"/>
        <value caption="CLK_PER divided by 17" name="DIV17" value="0x0F"/>
        <value caption="CLK_PER divided by 18" name="DIV18" value="0x10"/>
        <value caption="CLK_PER divided by 19" name="DIV19" value="0x11"/>
        <value caption="CLK_PER divided by 20" name="DIV20" value="0x12"/>
        <value caption="CLK_PER divided by 21" name="DIV21" value="0x13"/>
        <value caption="CLK_PER divided by 22" name="DIV22" value="0x14"/>
        <value caption="CLK_PER divided by 23" name="DIV23" value="0x15"/>
        <value caption="CLK_PER divided by 24" name="DIV24" value="0x16"/>
        <value caption="CLK_PER divided by 25" name="DIV25" value="0x17"/>
        <value caption="CLK_PER divided by 26" name="DIV26" value="0x18"/>
        <value caption="CLK_PER divided by 27" name="DIV27" value="0x19"/>
        <value caption="CLK_PER divided by 28" name="DIV28" value="0x1A"/>
        <value caption="CLK_PER divided by 29" name="DIV29" value="0x1B"/>
        <value caption="CLK_PER divided by 30" name="DIV30" value="0x1C"/>
        <value caption="CLK_PER divided by 31" name="DIV31" value="0x1D"/>
        <value caption="CLK_PER divided by 32" name="DIV32" value="0x1E"/>
      </value-group>
      <value-group caption="Reference Selection" name="ADC_REFSEL">
        <value caption="VDD" name="VDD" value="0x0"/>
        <value caption="External reference from EXTVREF0 pin" name="EXTVREF" value="0x2"/>
        <value caption="Internal reference 0.512 V" name="0V512" value="0x3"/>
        <value caption="Internal reference 1.024 V" name="1V024" value="0x4"/>
        <value caption="Internal reference 2.048 V" name="2V048" value="0x5"/>
        <value caption="Internal reference 4.096 V" name="4V096" value="0x6"/>
        <value caption="Internal reference 2.500 V" name="2V500" value="0x7"/>
      </value-group>
      <value-group caption="Window Comparator Mode select" name="ADC_WINCM">
        <value caption="No Window Comparison" name="NONE" value="0x00"/>
        <value caption="OUTPUT &lt; WINLT" name="BELOW" value="0x01"/>
        <value caption="OUTPUT &gt; WINHT" name="ABOVE" value="0x02"/>
        <value caption="WINLT &lt; OUTPUT &lt; WINHT" name="INSIDE" value="0x03"/>
        <value caption="OUTPUT &lt; WINLT or OUTPUT &gt;WINHT" name="OUTSIDE" value="0x04"/>
      </value-group>
      <value-group caption="Window Mode Source select" name="ADC_WINSRC">
        <value caption="Use RESULT[15:0] as Window Comparator Source" name="RESULT" value="0x0"/>
        <value caption="Use SAMPLE[15:0] as Window Comparator source" name="SAMPLE" value="0x1"/>
      </value-group>
      <value-group caption="Sample Accumulation Number Select" name="ADC_SAMPNUM">
        <value caption="No accumulation, single sample per conversion result" name="NONE" value="0x0"/>
        <value caption="2 samples accumulated" name="ACC2" value="0x1"/>
        <value caption="4 samples accumulated" name="ACC4" value="0x2"/>
        <value caption="8 samples accumulated" name="ACC8" value="0x3"/>
        <value caption="16 samples accumulated" name="ACC16" value="0x4"/>
        <value caption="32 samples accumulated" name="ACC32" value="0x5"/>
        <value caption="64 samples accumulated" name="ACC64" value="0x6"/>
        <value caption="128 samples accumulated" name="ACC128" value="0x7"/>
        <value caption="256 samples accumulated" name="ACC256" value="0x8"/>
        <value caption="512 samples accumulated" name="ACC512" value="0x9"/>
        <value caption="1024 samples accumulated" name="ACC1024" value="0xA"/>
      </value-group>
      <value-group caption="Result Scaling select" name="ADC_SCALING">
        <value caption="ADC output of sample or accumulated result is right adjusted. If accumulating more then 64 samples,
result is left adjusted" name="NORMAL" value="0x0"/>
        <value caption="ADC output is left adjusted" name="LEFTADJ" value="0x1"/>
        <value caption="Accumulated ADC result is averaged and right adjusted" name="AVERAGE" value="0x2"/>
      </value-group>
      <value-group caption="Positive Input Multiplexer select" name="ADC_MUXPOS">
        <value caption="ADC input pin 4" name="AIN4" value="0x04"/>
        <value caption="ADC input pin 5" name="AIN5" value="0x05"/>
        <value caption="ADC input pin 6" name="AIN6" value="0x06"/>
        <value caption="ADC input pin 7" name="AIN7" value="0x07"/>
        <value caption="ADC input pin 22" name="AIN22" value="0x16"/>
        <value caption="ADC input pin 23" name="AIN23" value="0x17"/>
        <value caption="ADC input pin 24" name="AIN24" value="0x18"/>
        <value caption="ADC input pin 25" name="AIN25" value="0x19"/>
        <value caption="ADC input pin 26" name="AIN26" value="0x1A"/>
        <value caption="ADC input pin 27" name="AIN27" value="0x1B"/>
        <value caption="Temperature Sensor" name="TEMPSENSE" value="0x29"/>
        <value caption="VDD Divided by 10" name="VDDDIV10" value="0x2A"/>
        <value caption="AC0 Reference Scaler" name="AC0REFSCALE" value="0x2B"/>
        <value caption="Peripheral Touch Controller" name="PTC" value="0x3E"/>
