    <module caption="Fuses" id="avrla" name="FUSE">
      <register-group caption="Fuses" name="FUSE" size="0x0C">
        <register caption="Watchdog Configuration" initval="0x00" name="WDTCFG" offset="0x0" rw="RW" size="1">
          <bitfield caption="Watchdog Timeout Period" mask="0x0F" name="PERIOD" rw="RW" values="FUSE_PERIOD"/>
          <bitfield caption="Watchdog Window Timeout Period" mask="0xF0" name="WINDOW" rw="RW" values="FUSE_WINDOW"/>
        </register>
        <register caption="BOD Configuration" initval="0x00" name="BODCFG" offset="0x1" rw="RW" size="1">
          <bitfield caption="BOD Operation in Sleep Mode" mask="0x03" name="SLEEP" rw="RW" values="FUSE_SLEEP"/>
          <bitfield caption="BOD Operation in Active Mode" mask="0x0C" name="ACTIVE" rw="RW" values="FUSE_ACTIVE"/>
          <bitfield caption="BOD Sample Frequency" mask="0x10" name="SAMPFREQ" rw="RW" values="FUSE_SAMPFREQ"/>
          <bitfield caption="BOD Level" mask="0xE0" name="LVL" rw="RW" values="FUSE_LVL"/>
        </register>
        <register caption="Oscillator Configuration" initval="0x00" name="OSCCFG" offset="0x2" rw="RW" size="1">
          <bitfield caption="High-frequency Oscillator Frequency" mask="0x08" name="OSCHFFRQ" rw="RW" values="FUSE_OSCHFFRQ"/>
        </register>
        <register caption="Pin Configuration" initval="0x02" name="PINCFG" offset="0x3" rw="RW" size="1">
          <bitfield caption="Reset Pin Configuration select" mask="0x01" name="RSTPINCFG" rw="RW" values="FUSE_RSTPINCFG"/>
          <bitfield caption="UPDI Pin Configuration select" mask="0x02" name="UPDIPINCFG" rw="RW" values="FUSE_UPDIPINCFG"/>
        </register>
        <register caption="Hardware Monitor Configuration" initval="0x00" name="HVMONCFG" offset="0x4" rw="RW" size="1">
          <bitfield caption="CPU Monitor" mask="0x01" name="CPUMON" rw="RW"/>
        </register>
        <register caption="System Configuration 0" initval="0x00" name="SYSCFG0" offset="0x5" rw="RW" size="1">
          <bitfield caption="EEPROM Save" mask="0x01" name="EESAVE" rw="RW"/>
          <bitfield caption="BOOTROW Save" mask="0x02" name="BOOTROWSAVE" rw="RW"/>
          <bitfield caption="CRC Select" mask="0x40" name="CRCSEL" rw="RW" values="FUSE_CRCSEL"/>
          <bitfield caption="CRC Check on Boot" mask="0x80" name="CRCBOOT" rw="RW"/>
        </register>
        <register caption="System Configuration 1" initval="0x07" name="SYSCFG1" offset="0x6" rw="RW" size="1">
          <bitfield caption="Startup Time" mask="0x07" name="SUT" rw="RW" values="FUSE_SUT"/>
        </register>
        <register caption="Code Section Size" initval="0x00" name="CODESIZE" offset="0x7" rw="RW" size="1"/>
        <register caption="Boot Section Size" initval="0x00" name="BOOTSIZE" offset="0x8" rw="RW" size="1"/>
        <register caption="UPDI Protection" initval="0x0003" name="PDICFG" offset="0xA" rw="RW" size="2">
          <bitfield caption="Protection Level" mask="0x03" name="LEVEL" rw="RW" values="FUSE_LEVEL"/>
          <bitfield caption="NVM Protection Activation Key" mask="0xFFF0" name="KEY" rw="RW" values="FUSE_KEY"/>
        </register>
      </register-group>
      <value-group caption="BOD Operation in Active Mode select" name="FUSE_ACTIVE">
        <value caption="Disabled" name="DISABLE" value="0x00"/>
        <value caption="Enabled in continuous mode" name="ENABLE" value="0x01"/>
        <value caption="Enabled in sampled mode" name="SAMPLE" value="0x02"/>
        <value caption="Enabled in continuous mode. Execution halted at wake-up until BOD is running" name="ENABLEWAIT" value="0x03"/>
      </value-group>
      <value-group caption="BOD Level select" name="FUSE_LVL">
        <value caption="1.65 V" name="BODLEVEL0" value="0x00"/>
        <value caption="1.90 V" name="BODLEVEL1" value="0x01"/>
        <value caption="2.60 V" name="BODLEVEL2" value="0x02"/>
        <value caption="4.30 V" name="BODLEVEL3" value="0x03"/>
      </value-group>
      <value-group caption="BOD Sample Frequency select" name="FUSE_SAMPFREQ">
        <value caption="Sampling frequency is 128 Hz" name="128HZ" value="0x0"/>
        <value caption="Sample frequency is 32 Hz" name="32HZ" value="0x1"/>
      </value-group>
      <value-group caption="BOD Operation in Sleep Mode select" name="FUSE_SLEEP">
        <value caption="Disabled" name="DISABLE" value="0x00"/>
        <value caption="Enabled in continuous mode" name="ENABLE" value="0x01"/>
        <value caption="Enabled in sampled mode" name="SAMPLE" value="0x02"/>
      </value-group>
      <value-group caption="High-frequency Oscillator Frequency select" name="FUSE_OSCHFFRQ">
        <value caption="OSCHF running at 20 MHz" name="20M" value="0x0"/>
        <value caption="OSCHF running at 16 MHz" name="16M" value="0x1"/>
      </value-group>
      <value-group caption="NVM Protection Activation Key select" name="FUSE_KEY">
        <value caption="Not active" name="NOTACT" value="0x0"/>
        <value caption="NVM protection active. Chip erase is disabled." name="NVMACT" value="0xB45"/>
      </value-group>
      <value-group caption="Protection Level select" name="FUSE_LEVEL">
        <value caption="NVM Access through UPDI disabled" name="NVMACCDIS" value="0x2"/>
        <value caption="UPDI interface is enabled" name="BASIC" value="0x3"/>
      </value-group>
      <value-group caption="Reset Pin Configuration select" name="FUSE_RSTPINCFG">
