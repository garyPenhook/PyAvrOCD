        </register>
        <register caption="Pin 3 Control" initval="0x00" name="PIN3CTRL" offset="0x13" rw="RW" size="1">
          <bitfield caption="Input/Sense Configuration" mask="0x07" name="ISC" rw="RW" values="PORT_ISC"/>
          <bitfield caption="Pullup enable" mask="0x08" name="PULLUPEN" rw="RW"/>
