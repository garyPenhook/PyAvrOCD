        <register caption="OSCHF Control A" initval="0x00" name="OSCHFCTRLA" offset="0x08" rw="RW" size="1">
          <bitfield caption="Automatic Oscillator Tune" mask="0x03" name="AUTOTUNE" rw="RW" values="CLKCTRL_AUTOTUNE"/>
