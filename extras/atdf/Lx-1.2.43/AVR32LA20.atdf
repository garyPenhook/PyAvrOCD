    <module caption="Non-volatile Memory Controller" id="nvm_ctrl_avr_v3" name="NVMCTRL">
      <register-group caption="Non-volatile Memory Controller" name="NVMCTRL" size="0x40">
        <register caption="Control A" initval="0x00" name="CTRLA" offset="0x00" rw="RW" size="1">
          <bitfield caption="Command" mask="0x7F" name="CMD" rw="RW" values="NVMCTRL_CMD"/>
        </register>
        <register caption="Control B" initval="0x30" name="CTRLB" offset="0x01" rw="RW" size="1">
          <bitfield caption="Application Code Write Protect" mask="0x01" name="APPCODEWP" rw="RW"/>
          <bitfield caption="Boot Read Protect" mask="0x02" name="BOOTRP" rw="RW"/>
          <bitfield caption="Application Data Write Protect" mask="0x04" name="APPDATAWP" rw="RW"/>
          <bitfield caption="EEPROM Write Protect" mask="0x08" name="EEWP" rw="RW"/>
          <bitfield caption="Flash Mapping in Data space" mask="0x30" name="FLMAP" rw="RW" values="NVMCTRL_FLMAP"/>
          <bitfield caption="Flash Mapping Lock" mask="0x80" name="FLMAPLOCK" rw="RW"/>
        </register>
        <register caption="Control C" initval="0x00" name="CTRLC" offset="0x02" rw="RW" size="1">
          <bitfield caption="User Row Write Protect" mask="0x01" name="UROWWP" rw="RW"/>
          <bitfield caption="Boot Row Write Protect" mask="0x02" name="BOOTROWWP" rw="RW"/>
        </register>
        <register caption="Interrupt Control" initval="0x00" name="INTCTRL" offset="0x04" rw="RW" size="1">
          <bitfield caption="EEPROM Ready" mask="0x01" name="EEREADY" rw="RW"/>
          <bitfield caption="Flash Ready" mask="0x02" name="FLREADY" rw="RW"/>
        </register>
        <register caption="Interrupt Flags" initval="0x00" name="INTFLAGS" offset="0x05" rw="RW" size="1">
          <bitfield caption="EEPROM Ready" mask="0x01" name="EEREADY" rw="RW"/>
          <bitfield caption="Flash Ready" mask="0x02" name="FLREADY" rw="RW"/>
        </register>
        <register caption="Status" initval="0x00" name="STATUS" offset="0x06" rw="RW" size="1">
          <bitfield caption="EEPROM busy" mask="0x01" name="EEBUSY" rw="R"/>
          <bitfield caption="Flash busy" mask="0x02" name="FLBUSY" rw="R"/>
          <bitfield caption="Write error" mask="0x70" name="ERROR" rw="RW" values="NVMCTRL_ERROR"/>
        </register>
        <register caption="Data" initval="0x0000" name="DATA" offset="0x08" rw="RW" size="2"/>
        <register caption="Address" initval="0x00000000" name="ADDR" offset="0x0C" rw="RW" size="4">
          <bitfield caption="Address" mask="0xFFFFFF" name="ADDR" rw="RW"/>
        </register>
      </register-group>
      <value-group caption="Command select" name="NVMCTRL_CMD">
        <value caption="No Command" name="NOCMD" value="0x00"/>
        <value caption="No Operation" name="NOOP" value="0x01"/>
        <value caption="Flash Page Write" name="FLPW" value="0x04"/>
        <value caption="Flash Page Erase and Write" name="FLPERW" value="0x05"/>
        <value caption="Flash Page Erase" name="FLPER" value="0x08"/>
        <value caption="Flash 2-page erase enable" name="FLMPER2" value="0x09"/>
        <value caption="Flash 4-page erase enable" name="FLMPER4" value="0x0A"/>
        <value caption="Flash 8-page erase enable" name="FLMPER8" value="0x0B"/>
        <value caption="Flash 16-page erase enable" name="FLMPER16" value="0x0C"/>
        <value caption="Flash 32-page erase enable" name="FLMPER32" value="0x0D"/>
        <value caption="Flash Page Buffer Clear" name="FLPBCLR" value="0x0F"/>
        <value caption="EEPROM Page Write" name="EEPW" value="0x14"/>
        <value caption="EEPROM Page Erase and Write" name="EEPERW" value="0x15"/>
        <value caption="EEPROM Page Erase" name="EEPER" value="0x17"/>
        <value caption="EEPROM Page Buffer Clear" name="EEPBCLR" value="0x1F"/>
        <value caption="Chip Erase Command (UPDI only)" name="CHER" value="0x20"/>
        <value caption="EEPROM Erase Command (UPDI only)" name="EECHER" value="0x30"/>
      </value-group>
      <value-group caption="Flash Mapping in Data space select" name="NVMCTRL_FLMAP">
        <value caption="Flash section 0, 0 - 32KB" name="SECTION0" value="0x0"/>
        <value caption="Flash section 1, 32 - 64KB" name="SECTION1" value="0x1"/>
        <value caption="Flash section 2, 64 - 96KB" name="SECTION2" value="0x2"/>
        <value caption="Flash section 3, 96 - 128KB" name="SECTION3" value="0x3"/>
      </value-group>
      <value-group caption="Write error select" name="NVMCTRL_ERROR">
        <value caption="No Error" name="NOERROR" value="0x0"/>
        <value caption="Attempt to program write protected area" name="WRITEPROTECT" value="0x2"/>
        <value caption="Selecting new write command while write command already seleted" name="CMDCOLLISION" value="0x3"/>
        <value caption="Address cannot be written with selected command" name="WRONGSECTION" value="0x4"/>
      </value-group>
    </module>
    <module caption="I/O Ports" id="gpio_ports_avr_v3_port" name="PORT">
      <register-group caption="I/O Ports" name="PORT" size="0x20">
        <register caption="Data Direction" initval="0x00" name="DIR" offset="0x00" rw="RW" size="1"/>
        <register caption="Data Direction Set" initval="0x00" name="DIRSET" offset="0x01" rw="RW" size="1"/>
