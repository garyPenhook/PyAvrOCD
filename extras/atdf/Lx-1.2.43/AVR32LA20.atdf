        <register caption="OSCHF Tune" initval="0x00" name="OSCHFTUNE" offset="0x09" rw="RW" size="1">
          <bitfield caption="Oscillator Tune" mask="0xFF" name="TUNE" rw="RW"/>
        </register>
        <register caption="OSC32K Control A" initval="0x00" name="OSC32KCTRLA" offset="0x18" rw="RW" size="1">
          <bitfield caption="Run in Standby Mode" mask="0x80" name="RUNSTDBY" rw="RW"/>
        </register>
        <register caption="XOSC32K Control A" initval="0x00" name="XOSC32KCTRLA" offset="0x1C" rw="RW" size="1">
          <bitfield caption="Enable" mask="0x01" name="ENABLE" rw="RW"/>
          <bitfield caption="Power Mode" mask="0x06" name="PMODE" rw="RW" values="CLKCTRL_PMODE"/>
          <bitfield caption="Source Select" mask="0x08" name="SEL" rw="RW" values="CLKCTRL_SEL"/>
          <bitfield caption="Crystal Oscillator Start-up Time" mask="0x30" name="CSUT" rw="RW" values="CLKCTRL_CSUT"/>
          <bitfield caption="Run in Standby Mode" mask="0x80" name="RUNSTDBY" rw="RW"/>
        </register>
      </register-group>
      <value-group caption="Clock select" name="CLKCTRL_CLKSEL">
        <value caption="Internal high-frequency oscillator" name="OSCHF" value="0x0"/>
        <value caption="Internal 32.768 kHz oscillator" name="OSC32K" value="0x1"/>
        <value caption="32.768 kHz crystal oscillator" name="XOSC32K" value="0x2"/>
        <value caption="External clock" name="EXTCLK" value="0x3"/>
      </value-group>
      <value-group caption="Prescaler division select" name="CLKCTRL_PDIV">
        <value caption="Divide by 2" name="DIV2" value="0x00"/>
        <value caption="Divide by 4" name="DIV4" value="0x01"/>
        <value caption="Divide by 8" name="DIV8" value="0x02"/>
        <value caption="Divide by 16" name="DIV16" value="0x03"/>
        <value caption="Divide by 32" name="DIV32" value="0x04"/>
        <value caption="Divide by 64" name="DIV64" value="0x05"/>
        <value caption="Divide by 6" name="DIV6" value="0x08"/>
        <value caption="Divide by 10" name="DIV10" value="0x09"/>
        <value caption="Divide by 12" name="DIV12" value="0x0A"/>
        <value caption="Divide by 24" name="DIV24" value="0x0B"/>
        <value caption="Divide by 48" name="DIV48" value="0x0C"/>
      </value-group>
      <value-group caption="Automatic Oscillator Tune select" name="CLKCTRL_AUTOTUNE">
        <value caption="Disabled" name="OFF" value="0x0"/>
        <value caption="Tune against 32.768 kHz Crystal Oscillator" name="XOSC32K" value="0x1"/>
      </value-group>
      <value-group caption="Crystal Oscillator Start-up Time select" name="CLKCTRL_CSUT">
        <value caption="1k cycles" name="1K" value="0x00"/>
        <value caption="16k cycles" name="16K" value="0x01"/>
        <value caption="32k cycles" name="32K" value="0x02"/>
        <value caption="64k cycles" name="64K" value="0x03"/>
      </value-group>
      <value-group caption="Power Mode select" name="CLKCTRL_PMODE">
        <value caption="Low Power Mode (Typ CL=8pF, ESR=50 kOhm)" name="LOW" value="0x00"/>
        <value caption="Medium Power Mode (Typ CL=12.5pF, ESR=70 kOhm)" name="MEDIUM" value="0x01"/>
        <value caption="High Power Mode (Up to CL=24pF, ESR=100 kOhm)" name="HIGH" value="0x02"/>
      </value-group>
      <value-group caption="Source Select" name="CLKCTRL_SEL">
        <value caption="External Crystal connected to the XTAL32K1 and XTAL32K2 pins" name="XTAL" value="0x0"/>
        <value caption="External Clock on XTAL32K1 pin" name="EXTCLK" value="0x1"/>
      </value-group>
