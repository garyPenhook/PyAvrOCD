                <enumeratedValue>
                  <name>OFF</name>
                  <description>No SDA Hold Delay</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>50NS</name>
                  <description>Short SDA hold time</description>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>300NS</name>
                  <description>Meets SMBUS 2.0 specification under typical conditions</description>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>500NS</name>
                  <description>Meets SMBUS 2.0 specificaiton across all corners</description>
                  <value>3</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>SDASETUP</name>
