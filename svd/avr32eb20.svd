                <enumeratedValue>
                  <name>ON</name>
                  <description>SCL duty cycle operating according to Fm specification</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>FMPEN</name>
              <description>Fast-mode Plus Enable</description>
              <bitRange>[1:1]</bitRange>
