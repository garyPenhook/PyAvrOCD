                <enumeratedValue>
                  <name>CODE</name>
                  <description>The CRC is performed on the application code section of Flash</description>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DATA</name>
                  <description>The CRC is performed on the application data section of Flash</description>
                  <value>2</value>
