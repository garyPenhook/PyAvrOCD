                  <name>OFF</name>
                  <description>SCL duty cycle operating according to Sm specification</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ON</name>
                  <description>SCL duty cycle operating according to Fm specification</description>
                  <value>1</value>
                </enumeratedValue>
