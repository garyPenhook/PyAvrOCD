                <enumeratedValue>
                  <name>BELOW</name>
                  <description>The voltage is below the VLM threshold level</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
          </fields>
        </register>
        <register>
          <name>VLMCTRLA</name>
