                  <name>DIV28</name>
                  <description>CLK_PER divided by 28</description>
                  <value>26</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DIV29</name>
                  <description>CLK_PER divided by 29</description>
                  <value>27</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DIV30</name>
                  <description>CLK_PER divided by 30</description>
                  <value>28</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DIV31</name>
                  <description>CLK_PER divided by 31</description>
                  <value>29</value>
