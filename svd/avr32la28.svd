                </enumeratedValue>
                <enumeratedValue>
                  <name>CRC32</name>
                  <description>The CRC is performed using CRC32</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>PEREN</name>
              <description>Enable Periodic Timer</description>
