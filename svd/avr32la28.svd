                <enumeratedValue>
                  <name>DIV22</name>
                  <description>CLK_PER divided by 22</description>
                  <value>20</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DIV23</name>
                  <description>CLK_PER divided by 23</description>
                  <value>21</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DIV24</name>
                  <description>CLK_PER divided by 24</description>
                  <value>22</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DIV25</name>
                  <description>CLK_PER divided by 25</description>
                  <value>23</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DIV26</name>
                  <description>CLK_PER divided by 26</description>
                  <value>24</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DIV27</name>
                  <description>CLK_PER divided by 27</description>
                  <value>25</value>
                </enumeratedValue>
