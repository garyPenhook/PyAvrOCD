                <enumeratedValue>
                  <name>UPDOWN</name>
                  <description>Count on prescaled clock. Event controls count direction. Up-count when event line is 0, down-count when event line is 1.</description>
                  <value>3</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>RESTART_POSEDGE</name>
                  <description>Restart counter at positive edge event</description>
                  <value>4</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>RESTART_ANYEDGE</name>
                  <description>Restart counter on any edge event</description>
                  <value>5</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>RESTART_HIGHLVL</name>
                  <description>Restart counter while event line is 1.</description>
